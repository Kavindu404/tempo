import torch
import torch.nn as nn
import torch.nn.functional as F

class MultiLabelCriterion(nn.Module):
    def __init__(self, criterion_type='bce', class_weights=None, pos_weight=None, 
                 focal_alpha=0.25, focal_gamma=2.0, label_smoothing=0.0):
        """
        Multi-label loss criterion
        
        Args:
            criterion_type: 'bce', 'focal', 'weighted_bce'
            class_weights: Class weights for imbalanced dataset
            pos_weight: Positive class weights for BCE
            focal_alpha: Alpha parameter for focal loss
            focal_gamma: Gamma parameter for focal loss
            label_smoothing: Label smoothing factor
        """
        super().__init__()
        self.criterion_type = criterion_type
        self.label_smoothing = label_smoothing
        
        if criterion_type == 'bce':
            self.criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
        elif criterion_type == 'weighted_bce':
            self.criterion = nn.BCEWithLogitsLoss(weight=class_weights, pos_weight=pos_weight)
        elif criterion_type == 'focal':
            self.focal_alpha = focal_alpha
            self.focal_gamma = focal_gamma
        else:
            raise ValueError(f"Unknown criterion type: {criterion_type}")
    
    def forward(self, logits, targets):
        """
        Args:
            logits: [batch_size, num_classes] - raw logits
            targets: [batch_size, num_classes] - binary targets
        """
        # Apply label smoothing if specified
        if self.label_smoothing > 0:
            targets = self._apply_label_smoothing(targets)
        
        if self.criterion_type == 'focal':
            return self._focal_loss(logits, targets)
        else:
            return self.criterion(logits, targets)
    
    def _apply_label_smoothing(self, targets):
        """Apply label smoothing to targets"""
        # For multi-label: smooth 1s towards (1-eps) and 0s towards eps
        eps = self.label_smoothing
        smoothed_targets = targets * (1 - eps) + eps * 0.5
        return smoothed_targets
    
    def _focal_loss(self, logits, targets):
        """Focal loss for multi-label classification"""
        # Convert logits to probabilities
        probs = torch.sigmoid(logits)
        
        # Calculate focal loss
        ce_loss = F.binary_cross_entropy_with_logits(logits, targets, reduction='none')
        
        # Calculate pt
        pt = probs * targets + (1 - probs) * (1 - targets)
        
        # Calculate alpha_t
        alpha_t = self.focal_alpha * targets + (1 - self.focal_alpha) * (1 - targets)
        
        # Calculate focal weight
        focal_weight = alpha_t * (1 - pt) ** self.focal_gamma
        
        # Apply focal weight
        focal_loss = focal_weight * ce_loss
        
        return focal_loss.mean()

class AsymmetricLoss(nn.Module):
    def __init__(self, gamma_neg=4, gamma_pos=1, clip=0.05, eps=1e-8):
        """
        Asymmetric Loss for multi-label classification
        Focuses more on hard negatives
        """
        super().__init__()
        self.gamma_neg = gamma_neg
        self.gamma_pos = gamma_pos
        self.clip = clip
        self.eps = eps

    def forward(self, logits, targets):
        # Sigmoid
        xs_pos = torch.sigmoid(logits)
        xs_neg = 1 - xs_pos

        # Asymmetric Clipping
        if self.clip is not None and self.clip > 0:
            xs_neg = (xs_neg + self.clip).clamp(max=1)

        # Basic CE calculation
        los_pos = targets * torch.log(xs_pos.clamp(min=self.eps))
        los_neg = (1 - targets) * torch.log(xs_neg.clamp(min=self.eps))

        # Asymmetric Focusing
        if self.gamma_neg > 0 or self.gamma_pos > 0:
            pt0 = xs_pos * targets
            pt1 = xs_neg * (1 - targets)
            pt = pt0 + pt1
            one_sided_gamma = self.gamma_pos * targets + self.gamma_neg * (1 - targets)
            one_sided_w = torch.pow(1 - pt, one_sided_gamma)
            loss = one_sided_w * (los_pos + los_neg)
        else:
            loss = los_pos + los_neg

        return -loss.mean()

def get_criterion(criterion_config, class_weights=None):
    """Factory function to create criterion based on config"""
    criterion_type = criterion_config.get('type', 'bce')
    
    if criterion_type == 'bce':
        return MultiLabelCriterion('bce', pos_weight=class_weights)
    elif criterion_type == 'focal':
        return MultiLabelCriterion(
            'focal', 
            focal_alpha=criterion_config.get('alpha', 0.25),
            focal_gamma=criterion_config.get('gamma', 2.0)
        )
    elif criterion_type == 'asymmetric':
        return AsymmetricLoss(
            gamma_neg=criterion_config.get('gamma_neg', 4),
            gamma_pos=criterion_config.get('gamma_pos', 1),
            clip=criterion_config.get('clip', 0.05)
        )
    else:
        raise ValueError(f"Unknown criterion type: {criterion_type}")


