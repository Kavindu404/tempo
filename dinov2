import torch
import numpy as np
from sklearn.metrics import average_precision_score, roc_auc_score, f1_score
import matplotlib.pyplot as plt
import seaborn as sns

def calculate_multilabel_metrics(predictions, targets, class_names, threshold=0.5):
    """
    Calculate comprehensive multi-label classification metrics
    
    Args:
        predictions: [N, C] tensor of probabilities
        targets: [N, C] tensor of binary targets
        class_names: List of class names
        threshold: Threshold for binary predictions
    """
    predictions = predictions.numpy() if torch.is_tensor(predictions) else predictions
    targets = targets.numpy() if torch.is_tensor(targets) else targets
    
    # Binary predictions
    binary_preds = (predictions > threshold).astype(int)
    
    # Calculate per-class metrics
    per_class_ap = []
    per_class_auc = []
    per_class_f1 = []
    
    for i in range(len(class_names)):
        # Average Precision (AP)
        if targets[:, i].sum() > 0:  # Only if positive samples exist
            ap = average_precision_score(targets[:, i], predictions[:, i])
            per_class_ap.append(ap)
        else:
            per_class_ap.append(0.0)
        
        # AUC-ROC
        if len(np.unique(targets[:, i])) > 1:  # Only if both classes exist
            auc = roc_auc_score(targets[:, i], predictions[:, i])
            per_class_auc.append(auc)
        else:
            per_class_auc.append(0.5)
        
        # F1 Score
        f1 = f1_score(targets[:, i], binary_preds[:, i], zero_division=0)
        per_class_f1.append(f1)
    
    # Overall metrics
    mAP = np.mean(per_class_ap)
    mAUC = np.mean(per_class_auc)
    mF1 = np.mean(per_class_f1)
    
    # Exact match ratio (all labels correct)
    exact_match = np.mean(np.all(binary_preds == targets, axis=1))
    
    # Hamming loss (fraction of incorrect labels)
    hamming_loss = np.mean(binary_preds != targets)
    
    # Subset accuracy (exact match)
    subset_accuracy = exact_match
    
    metrics = {
        'mAP': mAP,
        'mAUC': mAUC,
        'mF1': mF1,
        'exact_match': exact_match,
        'hamming_loss': hamming_loss,
        'subset_accuracy': subset_accuracy,
        'per_class_ap': per_class_ap,
        'per_class_auc': per_class_auc,
        'per_class_f1': per_class_f1,
        'class_names': class_names
    }
    
    return metrics

