import json
import os
from PIL import Image
import torch
from torch.utils.data import Dataset
import torchvision.transforms as transforms
from collections import defaultdict
import numpy as np

class COCOMultiLabelDataset(Dataset):
    def __init__(self, annotation_file, image_dir, transform=None, min_bbox_area=100):
        """
        COCO dataset for multi-label classification from bboxes
        
        Args:
            annotation_file: Path to COCO JSON file
            image_dir: Directory containing images
            transform: Image transforms
            min_bbox_area: Minimum bbox area to include
        """
        with open(annotation_file, 'r') as f:
            self.coco_data = json.load(f)
        
        self.image_dir = image_dir
        self.transform = transform
        self.min_bbox_area = min_bbox_area
        
        # Build mappings
        self.images = {img['id']: img for img in self.coco_data['images']}
        self.categories = {cat['id']: cat for cat in self.coco_data['categories']}
        
        # Create category_id to index mapping
        self.category_ids = sorted(list(self.categories.keys()))
        self.cat_id_to_idx = {cat_id: idx for idx, cat_id in enumerate(self.category_ids)}
        self.idx_to_cat_id = {idx: cat_id for cat_id, idx in self.cat_id_to_idx.items()}
        
        # Group annotations by image for multi-label
        self.image_annotations = self._group_annotations_by_image()
        
        # Create list of valid image IDs
        self.image_ids = list(self.image_annotations.keys())
        
        print(f"Loaded {len(self.image_ids)} images with {len(self.category_ids)} categories")
        self._print_dataset_stats()
    
    def _group_annotations_by_image(self):
        """Group annotations by image_id and filter valid ones"""
        image_annotations = defaultdict(list)
        
        for ann in self.coco_data['annotations']:
            # Check if image exists
            if ann['image_id'] not in self.images:
                continue
            
            # Check bbox area
            bbox = ann['bbox']
            area = bbox[2] * bbox[3]
            if area < self.min_bbox_area:
                continue
            
            # Check if category exists
            if ann['category_id'] not in self.categories:
                continue
            
            image_annotations[ann['image_id']].append(ann)
        
        return dict(image_annotations)
    
    def _print_dataset_stats(self):
        """Print dataset statistics"""
        category_counts = defaultdict(int)
        total_annotations = 0
        
        for image_id, annotations in self.image_annotations.items():
            unique_categories = set()
            for ann in annotations:
                unique_categories.add(ann['category_id'])
            
            for cat_id in unique_categories:
                category_counts[cat_id] += 1
            
            total_annotations += len(annotations)
        
        print(f"\nDataset Statistics:")
        print(f"Total images: {len(self.image_ids)}")
        print(f"Total annotations: {total_annotations}")
        print(f"Average annotations per image: {total_annotations/len(self.image_ids):.2f}")
        
        print("\nCategory distribution (images containing each category):")
        for cat_id in self.category_ids:
            cat_name = self.categories[cat_id]['name']
            count = category_counts[cat_id]
            print(f"  {cat_name}: {count} images")
        
        # Multi-label statistics
        labels_per_image = []
        for annotations in self.image_annotations.values():
            unique_categories = len(set(ann['category_id'] for ann in annotations))
            labels_per_image.append(unique_categories)
        
        print(f"\nMulti-label statistics:")
        print(f"Average labels per image: {np.mean(labels_per_image):.2f}")
        print(f"Max labels per image: {max(labels_per_image)}")
        print(f"Min labels per image: {min(labels_per_image)}")
    
    def __len__(self):
        return len(self.image_ids)
    
    def __getitem__(self, idx):
        image_id = self.image_ids[idx]
        annotations = self.image_annotations[image_id]
        
        # Load image
        image_info = self.images[image_id]
        image_path = os.path.join(self.image_dir, image_info['file_name'])
        image = Image.open(image_path).convert('RGB')
        
        # For multi-label, we'll use the full image instead of cropping
        # You can modify this to use the largest bbox or combine multiple bboxes
        
        # Create multi-label target
        target = torch.zeros(len(self.category_ids), dtype=torch.float32)
        category_ids_in_image = set()
        
        for ann in annotations:
            cat_idx = self.cat_id_to_idx[ann['category_id']]
            target[cat_idx] = 1.0
            category_ids_in_image.add(ann['category_id'])
        
        # Apply transforms
        original_image = image.copy()  # Keep for visualization
        if self.transform:
            image = self.transform(image)
        
        return {
            'image': image,
            'target': target,
            'image_id': image_id,
            'category_ids': list(category_ids_in_image),
            'original_image': original_image,
            'file_name': image_info['file_name']
        }
    
    def get_class_names(self):
        """Get class names in model index order"""
        return [self.categories[cat_id]['name'] for cat_id in self.category_ids]
    
    def get_class_weights(self):
        """Calculate class weights for imbalanced dataset"""
        category_counts = defaultdict(int)
        total_images = len(self.image_ids)
        
        for annotations in self.image_annotations.values():
            unique_categories = set(ann['category_id'] for ann in annotations)
            for cat_id in unique_categories:
                category_counts[cat_id] += 1
        
        weights = []
        for cat_id in self.category_ids:
            count = category_counts[cat_id]
            weight = total_images / (len(self.category_ids) * count) if count > 0 else 1.0
            weights.append(weight)
        
        return torch.FloatTensor(weights)

def create_transforms(image_size=224, is_training=True):
    """Create transforms for DINOv2"""
    if is_training:
        transform = transforms.Compose([
            transforms.Resize((image_size, image_size)),
            transforms.RandomHorizontalFlip(p=0.5),
            transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2, hue=0.1),
            transforms.RandomRotation(10),
            transforms.ToTensor(),
            transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
        ])
    else:
        transform = transforms.Compose([
            transforms.Resize((image_size, image_size)),
            transforms.ToTensor(),
            transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
        ])
    
    return transform

def collate_fn(batch):
    """Custom collate function for multi-label data"""
    images = torch.stack([item['image'] for item in batch])
    targets = torch.stack([item['target'] for item in batch])
    
    # Keep other information as lists
    image_ids = [item['image_id'] for item in batch]
    category_ids = [item['category_ids'] for item in batch]
    original_images = [item['original_image'] for item in batch]
    file_names = [item['file_name'] for item in batch]
    
    return {
        'images': images,
        'targets': targets,
        'image_ids': image_ids,
        'category_ids': category_ids,
        'original_images': original_images,
        'file_names': file_names
    }






