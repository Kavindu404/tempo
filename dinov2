import torch
import torch.nn as nn
import time
import os
from collections import defaultdict
import matplotlib.pyplot as plt
import json

class MultiLabelTrainer:
    def __init__(self, model, criterion, optimizer, scheduler, device, 
                 class_names, save_dir='./checkpoints'):
        self.model = model
        self.criterion = criterion
        self.optimizer = optimizer
        self.scheduler = scheduler
        self.device = device
        self.class_names = class_names
        self.save_dir = save_dir
        
        os.makedirs(save_dir, exist_ok=True)
        
        # Training tracking
        self.train_losses = []
        self.val_losses = []
        self.val_map_scores = []
        self.learning_rates = []
        self.epoch_times = []
        
        self.best_val_score = 0
        self.best_model_state = None
        
        # Attention visualizer
        from model import AttentionVisualizer
        self.attention_visualizer = AttentionVisualizer()
    
    def train_epoch(self, train_loader, epoch, visualize_attention_every=200):
        """Train for one epoch"""
        self.model.train()
        running_loss = 0.0
        num_samples = 0
        
        for batch_idx, batch in enumerate(train_loader):
            images = batch['images'].to(self.device)
            targets = batch['targets'].to(self.device)
            
            self.optimizer.zero_grad()
            
            # Forward pass
            if batch_idx % visualize_attention_every == 0 and batch_idx > 0:
                # Get attention for visualization
                logits, attention_weights, cls_features = self.model(images, return_attention=True)
                
                # Visualize attention for first image in batch
                if attention_weights is not None:
                    with torch.no_grad():
                        probs = torch.sigmoid(logits[0])
                        original_img = batch['original_images'][0]
                        
                        save_path = os.path.join(self.save_dir, f'attention_epoch_{epoch}_batch_{batch_idx}.png')
                        self.attention_visualizer.visualize_attention(
                            images[0], attention_weights[0] if len(attention_weights.shape) > 3 else attention_weights,
                            probs, self.class_names, save_path=save_path
                        )
            else:
                logits = self.model(images)
            
            loss = self.criterion(logits, targets)
            loss.backward()
            self.optimizer.step()
            
            running_loss += loss.item() * images.size(0)
            num_samples += images.size(0)
            
            if batch_idx % 50 == 0:
                current_lr = self.optimizer.param_groups[0]['lr']
                print(f'Epoch {epoch}, Batch {batch_idx}, Loss: {loss.item():.4f}, LR: {current_lr:.6f}')
        
        avg_loss = running_loss / num_samples
        return avg_loss
    
    def validate(self, val_loader):
        """Validate model"""
        self.model.eval()
        running_loss = 0.0
        num_samples = 0
        
        all_predictions = []
        all_targets = []
       
       with torch.no_grad():
           for batch in val_loader:
               images = batch['images'].to(self.device)
               targets = batch['targets'].to(self.device)
               
               logits = self.model(images)
               loss = self.criterion(logits, targets)
               
               running_loss += loss.item() * images.size(0)
               num_samples += images.size(0)
               
               # Store predictions and targets for metrics
               probs = torch.sigmoid(logits)
               all_predictions.append(probs.cpu())
               all_targets.append(targets.cpu())
       
       avg_loss = running_loss / num_samples
       
       # Calculate metrics
       all_predictions = torch.cat(all_predictions)
       all_targets = torch.cat(all_targets)
       
       from utils import calculate_multilabel_metrics
       metrics = calculate_multilabel_metrics(all_predictions, all_targets, self.class_names)
       
       return avg_loss, metrics
   
   def train(self, train_loader, val_loader, epochs, visualize_attention_every=200):
       """Full training loop"""
       print(f"Starting training for {epochs} epochs...")
       
       for epoch in range(epochs):
           start_time = time.time()
           
           # Train
           train_loss = self.train_epoch(train_loader, epoch, visualize_attention_every)
           
           # Validate
           val_loss, val_metrics = self.validate(val_loader)
           
           # Update scheduler
           if self.scheduler:
               self.scheduler.step()
           
           epoch_time = time.time() - start_time
           
           # Track metrics
           current_lr = self.optimizer.param_groups[0]['lr']
           val_map = val_metrics['mAP']
           
           self.train_losses.append(train_loss)
           self.val_losses.append(val_loss)
           self.val_map_scores.append(val_map)
           self.learning_rates.append(current_lr)
           self.epoch_times.append(epoch_time)
           
           # Print progress
           print(f'Epoch {epoch}: Train Loss: {train_loss:.4f}, Val Loss: {val_loss:.4f}, '
                 f'Val mAP: {val_map:.4f}, Time: {epoch_time:.1f}s')
           
           # Save best model
           if val_map > self.best_val_score:
               self.best_val_score = val_map
               self.best_model_state = self.model.state_dict().copy()
               print(f'New best validation mAP: {self.best_val_score:.4f}')
               
               # Save checkpoint
               self._save_checkpoint(epoch, val_metrics)
           
           # Plot training curves every 10 epochs
           if (epoch + 1) % 10 == 0:
               self.plot_training_curves()
       
       # Load best model
       if self.best_model_state:
           self.model.load_state_dict(self.best_model_state)
           print(f'Loaded best model with validation mAP: {self.best_val_score:.4f}')
       
       # Final plots and save
       self.plot_training_curves()
       self.save_training_history()
       
       return self.model
   
   def _save_checkpoint(self, epoch, metrics):
       """Save model checkpoint"""
       checkpoint = {
           'epoch': epoch,
           'model_state_dict': self.best_model_state,
           'optimizer_state_dict': self.optimizer.state_dict(),
           'scheduler_state_dict': self.scheduler.state_dict() if self.scheduler else None,
           'val_metrics': metrics,
           'train_losses': self.train_losses,
           'val_losses': self.val_losses,
           'val_map_scores': self.val_map_scores
       }
       
       checkpoint_path = os.path.join(self.save_dir, f'best_model_epoch_{epoch}.pth')
       torch.save(checkpoint, checkpoint_path)
       print(f'Checkpoint saved: {checkpoint_path}')
   
   def plot_training_curves(self):
       """Plot training curves"""
       epochs = range(1, len(self.train_losses) + 1)
       
       fig, axes = plt.subplots(2, 2, figsize=(15, 10))
       
