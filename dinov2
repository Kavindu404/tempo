import torch
import torch.nn as nn
from torch.utils.data import DataLoader
import argparse
import os
import json

from dataset import COCOMultiLabelDataset, create_transforms, collate_fn
from model import DINOv2MultiLabelClassifier, ProductionDINOv2MultiLabelClassifier
from criterion import get_criterion
from trainer import MultiLabelTrainer
from eval import MultiLabelEvaluator
from utils import print_model_stats

def parse_args():
    parser = argparse.ArgumentParser(description='Multi-label COCO Classification with DINOv2')
    
    # Data arguments
    parser.add_argument('--train_ann', type=str, required=True,
                       help='Path to training annotations JSON')
    parser.add_argument('--val_ann', type=str, required=True,
                       help='Path to validation annotations JSON')
    parser.add_argument('--test_ann', type=str, required=True,
                       help='Path to test annotations JSON')
    parser.add_argument('--image_dir', type=str, required=True,
                       help='Directory containing images')
    
    # Model arguments
    parser.add_argument('--lora_r', type=int, default=16,
                       help='LoRA rank')
    parser.add_argument('--lora_alpha', type=int, default=32,
                       help='LoRA alpha')
    
    # Training arguments
    parser.add_argument('--batch_size', type=int, default=32,
                       help='Batch size')
    parser.add_argument('--epochs', type=int, default=50,
                       help='Number of epochs')
    parser.add_argument('--lr', type=float, default=1e-4,
                       help='Learning rate')
    parser.add_argument('--weight_decay', type=float, default=0.01,
                       help='Weight decay')
    
    # Loss arguments
    parser.add_argument('--criterion', type=str, default='bce',
                       choices=['bce', 'focal', 'asymmetric'],
                       help='Loss criterion')
    parser.add_argument('--focal_alpha', type=float, default=0.25,
                       help='Focal loss alpha')
    parser.add_argument('--focal_gamma', type=float, default=2.0,
                       help='Focal loss gamma')
    
    # Visualization arguments
    parser.add_argument('--visualize_attention_every', type=int, default=200,
                       help='Visualize attention every N batches')
    parser.add_argument('--num_attention_samples', type=int, default=10,
                       help='Number of attention samples to visualize during evaluation')
    
    # Output arguments
    parser.add_argument('--save_dir', type=str, default='./outputs',
                       help='Directory to save outputs')
    parser.add_argument('--checkpoint_dir', type=str, default='./checkpoints',
                       help='Directory to save checkpoints')
    
    # Evaluation arguments
    parser.add_argument('--threshold', type=float, default=0.5,
                       help='Threshold for binary predictions')
    parser.add_argument('--eval_only', action='store_true',
                       help='Only run evaluation')
    parser.add_argument('--checkpoint_path', type=str,
                       help='Path to checkpoint for evaluation')
    
    return parser.parse_args()

def setup_data(args):
    """Setup datasets and data loaders"""
    print("Setting up datasets...")
    
    # Create datasets
    train_dataset = COCOMultiLabelDataset(
        args.train_ann, args.image_dir,
        transform=create_transforms(is_training=True)
    )
    
    val_dataset = COCOMultiLabelDataset(
        args.val_ann, args.image_dir,
        transform=create_transforms(is_training=False)
    )
    
    test_dataset = COCOMultiLabelDataset(
        args.test_ann, args.image_dir,
        transform=create_transforms(is_training=False)
    )
    
    # Create data loaders
    train_loader = DataLoader(
        train_dataset, 
        batch_size=args.batch_size, 
        shuffle=True, 
        num_workers=4,
        collate_fn=collate_fn
    )
    
    val_loader = DataLoader(
        val_dataset, 
        batch_size=args.batch_size, 
        shuffle=False, 
        num_workers=4,
        collate_fn=collate_fn
    )
    
    test_loader = DataLoader(
        test_dataset, 
        batch_size=args.batch_size, 
        shuffle=False, 
        num_workers=4,
        collate_fn=collate_fn
    )
    
    return train_loader, val_loader, test_loader, train_dataset

def setup_model(num_classes, args, device):
    """Setup model, criterion, optimizer, and scheduler"""
    print("Setting up model...")
    
    # Create model
    model = DINOv2MultiLabelClassifier(
        num_classes=num_classes,
        r=args.lora_r,
        alpha=args.lora_alpha
    ).to(device)
    
    print_model_stats(model)
    
    # Create criterion
    criterion_config = {
        'type': args.criterion,
        'alpha': args.focal_alpha,
        'gamma': args.focal_gamma
    }
    criterion = get_criterion(criterion_config)
    
    # Create optimizer
    optimizer = torch.optim.AdamW(
        model.get_lora_parameters(),
        lr=args.lr,
        weight_decay=args.weight_decay
    )
    
    # Create scheduler
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(
        optimizer, T_max=args.epochs
    )
    
    return model, criterion, optimizer, scheduler

def train_model(model, criterion, optimizer, scheduler, train_loader, val_loader, 
                class_names, args, device):
    """Train the model"""
    print("Starting training...")
    
    trainer = MultiLabelTrainer(
        model=model,
        criterion=criterion,
        optimizer=optimizer,
        scheduler=scheduler,
        device=device,
        class_names=class_names,
        save_dir=args.checkpoint_dir
    )
    
    trained_model = trainer.train(
        train_loader=train_loader,
        val_loader=val_loader,
        epochs=args.epochs,
        visualize_attention_every=args.visualize_attention_every
    )
    
    # Save final model
    final_model_path = os.path.join(args.checkpoint_dir, 'final_model.pth')
    trained_model.merge_and_save(final_model_path)
    
    return trained_model, final_model_path

def evaluate_model(model_path, test_loader, class_names, args, device):
    """Evaluate the model"""
    print("Starting evaluation...")
    
    # Load production model
    model = ProductionDINOv2MultiLabelClassifier.from_lora_checkpoint(model_path)
    model = model.to(device)
    
    # Create evaluator
    evaluator = MultiLabelEvaluator(
        model=model,
        class_names=class_names,
        device=device,
        save_dir=args.save_dir
    )
    
    # Run evaluation
    metrics = evaluator.evaluate(
        test_loader=test_loader,
        threshold=args.threshold,
        visualize_attention=True,
        num_attention_samples=args.num_attention_samples
    )
    
    # Additional analysis
    evaluator.analyze_top_predictions(test_loader, top_k=5)
    
    return metrics

def main():
    args = parse_args()
    
    # Create output directories
    os.makedirs(args.save_dir, exist_ok=True)
    os.makedirs(args.checkpoint_dir, exist_ok=True)
    
    # Setup device
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
    print(f"Using device: {device}")
    
    # Setup data
    train_loader, val_loader, test_loader, train_dataset = setup_data(args)
    
    # Get class information
    class_names = train_dataset.get_class_names()
    num_classes = len(class_names)
    
    print(f"Number of classes: {num_classes}")
    print(f"Classes: {class_names}")
    
    if args.eval_only:
        # Evaluation only
        if not args.checkpoint_path:
            raise ValueError("checkpoint_path required for evaluation")
        
        metrics = evaluate_model(
            args.checkpoint_path, test_loader, class_names, args, device
        )
        
    else:
        # Training + Evaluation
        model, criterion, optimizer, scheduler = setup_model(num_classes, args, device)
        
        # Train model
        trained_model, model_path = train_model(
            model, criterion, optimizer, scheduler,
            train_loader, val_loader, class_names, args, device
        )
        
        # Evaluate model
        metrics = evaluate_model(model_path, test_loader, class_names, args, device)
    
    # Save configuration
    config = {
        'args': vars(args),
        'class_names': class_names,
        'num_classes': num_classes,
        'final_metrics': {
            'mAP': metrics['mAP'],
            'mAUC': metrics['mAUC'],
            'mF1': metrics['mF1'],
            'exact_match': metrics['exact_match']
        }
    }
    
    with open(os.path.join(args.save_dir, 'config.json'), 'w') as f:
        json.dump(config, f, indent=2)
    
    print("\n" + "="*60)
    print("FINAL RESULTS")
    print("="*60)
    print(f"mAP: {metrics['mAP']:.4f}")
    print(f"mAUC: {metrics['mAUC']:.4f}")
    print(f"mF1: {metrics['mF1']:.4f}")
    print(f"Exact Match: {metrics['exact_match']:.4f}")
    print(f"Results saved to: {args.save_dir}")

if __name__ == "__main__":
    main()






