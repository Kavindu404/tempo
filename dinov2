import torch
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import classification_report
import json
import os
from utils import calculate_multilabel_metrics, print_detailed_metrics, plot_per_class_metrics

class MultiLabelEvaluator:
    def __init__(self, model, class_names, device, save_dir='./evaluation'):
        self.model = model
        self.class_names = class_names
        self.device = device
        self.save_dir = save_dir
        
        os.makedirs(save_dir, exist_ok=True)
        
        # Import attention visualizer
        from model import AttentionVisualizer
        self.attention_visualizer = AttentionVisualizer()
    
    def evaluate(self, test_loader, threshold=0.5, visualize_attention=True, 
                num_attention_samples=10):
        """Comprehensive evaluation of multi-label classifier"""
        print("Starting comprehensive evaluation...")
        
        self.model.eval()
        all_predictions = []
        all_targets = []
        all_image_ids = []
        attention_samples = []
        
        with torch.no_grad():
            for batch_idx, batch in enumerate(test_loader):
                images = batch['images'].to(self.device)
                targets = batch['targets'].to(self.device)
                
                # Get predictions and attention
                if visualize_attention and len(attention_samples) < num_attention_samples:
                    logits, attention_weights = self.model(images, return_attention=True)
                    
                    # Store attention samples
                    for i in range(min(2, images.size(0))):
                        if len(attention_samples) < num_attention_samples:
                            attention_samples.append({
                                'image': images[i],
                                'attention': attention_weights[i] if attention_weights is not None else None,
                                'predictions': torch.sigmoid(logits[i]),
                                'targets': targets[i],
                                'original_image': batch['original_images'][i],
                                'file_name': batch['file_names'][i]
                            })
                else:
                    logits = self.model(images)
                
                predictions = torch.sigmoid(logits)
                
                all_predictions.append(predictions.cpu())
                all_targets.append(targets.cpu())
                all_image_ids.extend(batch['image_ids'])
        
        # Concatenate all results
        all_predictions = torch.cat(all_predictions)
        all_targets = torch.cat(all_targets)
        
        # Calculate metrics
        metrics = calculate_multilabel_metrics(all_predictions, all_targets, self.class_names, threshold)
        
        # Print results
        print_detailed_metrics(metrics)
        
        # Generate visualizations
        self._plot_metrics(metrics)
        self._plot_threshold_analysis(all_predictions, all_targets)
        self._plot_confusion_matrices(all_predictions, all_targets, threshold)
        
        if visualize_attention and attention_samples:
            self._visualize_attention_samples(attention_samples)
        
        # Save results
        self._save_results(metrics, all_predictions, all_targets, all_image_ids, threshold)
        
        return metrics
    
    def _plot_metrics(self, metrics):
        """Plot per-class metrics"""
        plot_per_class_metrics(metrics, save_path=os.path.join(self.save_dir, 'per_class_metrics.png'))
    
    def _plot_threshold_analysis(self, predictions, targets):
        """Analyze performance across different thresholds"""
        thresholds = np.linspace(0.1, 0.9, 9)
        map_scores = []
        f1_scores = []
        
        for thresh in thresholds:
            metrics = calculate_multilabel_metrics(predictions, targets, self.class_names, thresh)
            map_scores.append(metrics['mAP'])
            f1_scores.append(metrics['mF1'])
        
        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))
        
        ax1.plot(thresholds, map_scores, 'bo-', linewidth=2, markersize=8)
        ax1.set_title('mAP vs Threshold')
        ax1.set_xlabel('Threshold')
        ax1.set_ylabel('mAP')
        ax1.grid(True, alpha=0.3)
        
        ax2.plot(thresholds, f1_scores, 'ro-', linewidth=2, markersize=8)
        ax2.set_title('mF1 vs Threshold')
        ax2.set_xlabel('Threshold')
        ax2.set_ylabel('mF1')
        ax2.grid(True, alpha=0.3)
        
        plt.tight_layout()
        plt.savefig(os.path.join(self.save_dir, 'threshold_analysis.png'), 
                   dpi=150, bbox_inches='tight')
        plt.show()
        
        # Find optimal threshold
        optimal_idx = np.argmax(f1_scores)
        optimal_threshold = thresholds[optimal_idx]
        print(f"\nOptimal threshold for F1: {optimal_threshold:.2f} (F1: {f1_scores[optimal_idx]:.4f})")
    
    def _plot_confusion_matrices(self, predictions, targets, threshold):
        """Plot confusion matrices for each class"""
        binary_preds = (predictions > threshold).numpy()
        targets_np = targets.numpy()
        
        num_classes = len(self.class_names)
        cols = 4
        rows = (num_classes + cols - 1) // cols
        
        fig, axes = plt.subplots(rows, cols, figsize=(4*cols, 3*rows))
        if rows == 1:
            axes = axes.reshape(1, -1)
        
        for i, class_name in enumerate(self.class_names):
            row = i // cols
            col = i % cols
            
            # Create confusion matrix for this class
            cm = np.zeros((2, 2))
            cm[0, 0] = np.sum((targets_np[:, i] == 0) & (binary_preds[:, i] == 0))  # TN
            cm[0, 1] = np.sum((targets_np[:, i] == 0) & (binary_preds[:, i] == 1))  # FP
            cm[1, 0] = np.sum((targets_np[:, i] == 1) & (binary_preds[:, i] == 0))  # FN
            cm[1, 1] = np.sum((targets_np[:, i] == 1) & (binary_preds[:, i] == 1))  # TP
            
            sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                       xticklabels=['Neg', 'Pos'],
                       yticklabels=['Neg', 'Pos'],
                       ax=axes[row, col])
            axes[row, col].set_title(f'{class_name}')
            axes[row, col].set_xlabel('Predicted')
            axes[row, col].set_ylabel('Actual')
        
        # Hide unused subplots
        for i in range(num_classes, rows * cols):
            row = i // cols
            col = i % cols
            axes[row, col].axis('off')
        
        plt.tight_layout()
        plt.savefig(os.path.join(self.save_dir, 'confusion_matrices.png'), 
                   dpi=150, bbox_inches='tight')
        plt.show()
    
    def _visualize_attention_samples(self, attention_samples):
        """Visualize attention for sample predictions"""
        print("Visualizing attention maps...")
        
        for i, sample in enumerate(attention_samples):
            save_path = os.path.join(self.save_dir, f'attention_sample_{i}.png')
            
            self.attention_visualizer.visualize_attention(
                sample['image'],
                sample['attention'],
                sample['predictions'],
                self.class_names,
                save_path=save_path
            )
    
    def _save_results(self, metrics, predictions, targets, image_ids, threshold):
        """Save detailed evaluation results"""
        # Convert tensors to lists for JSON serialization
        predictions_list = predictions.numpy().tolist()
        targets_list = targets.numpy().tolist()
        
        # Binary predictions
        binary_preds = (predictions > threshold).numpy().tolist()
        
        results = {
            'metrics': {
                'mAP': metrics['mAP'],
                'mAUC': metrics['mAUC'],
                'mF1': metrics['mF1'],
                'exact_match': metrics['exact_match'],
                'hamming_loss': metrics['hamming_loss'],
                'subset_accuracy': metrics['subset_accuracy'],
                'per_class_ap': metrics['per_class_ap'],
                'per_class_auc': metrics['per_class_auc'],
                'per_class_f1': metrics['per_class_f1']
            },
            'predictions': {
                'image_ids': image_ids,
                'probabilities': predictions_list,
                'binary_predictions': binary_preds,
                'targets': targets_list,
                'threshold': threshold
            },
            'class_names': self.class_names
        }
        
        # Save to JSON
        with open(os.path.join(self.save_dir, 'evaluation_results.json'), 'w') as f:
            json.dump(results, f, indent=2)
        
        print(f"\nEvaluation results saved to {self.save_dir}")
    
    def analyze_top_predictions(self, test_loader, top_k=5):
        """Analyze top-k confident predictions for each class"""
        self.model.eval()
        
        class_predictions = {i: [] for i in range(len(self.class_names))}
        
        with torch.no_grad():
            for batch in test_loader:
                images = batch['images'].to(self.device)
                targets = batch['targets'].to(self.device)
                
                logits = self.model(images)
                predictions = torch.sigmoid(logits)
                
                for i in range(images.size(0)):
                    for class_idx in range(len(self.class_names)):
                        class_predictions[class_idx].append({
                            'confidence': predictions[i, class_idx].item(),
                            'target': targets[i, class_idx].item(),
                            'image_id': batch['image_ids'][i],
                            'file_name': batch['file_names'][i]
                        })
        
        # Analyze top predictions for each class
        print("\nTop Confident Predictions Analysis:")
        print("="*60)
        
        for class_idx, class_name in enumerate(self.class_names):
            # Sort by confidence
            sorted_preds = sorted(class_predictions[class_idx], 
                                key=lambda x: x['confidence'], reverse=True)
            
            top_preds = sorted_preds[:top_k]
           
           # Calculate accuracy of top predictions
           correct = sum(1 for pred in top_preds if pred['target'] == 1)
           accuracy = correct / len(top_preds)
           
           print(f"\n{class_name}:")
           print(f"  Top-{top_k} confidence accuracy: {accuracy:.3f} ({correct}/{len(top_preds)})")
           print(f"  Confidence range: {top_preds[-1]['confidence']:.3f} - {top_preds[0]['confidence']:.3f}")
           
           # Show individual predictions
           for j, pred in enumerate(top_preds):
               status = "✓" if pred['target'] == 1 else "✗"
               print(f"    {j+1}. {pred['file_name'][:30]:<30} "
                     f"Conf: {pred['confidence']:.3f} {status}")


