class LoRALinear(nn.Module):
    def __init__(self, original_layer, r=16, alpha=32, dropout=0.1):
        super().__init__()
        self.original_layer = original_layer
        self.r = r
        self.alpha = alpha
        self.scaling = alpha / r
        
        # Freeze original weights
        for param in self.original_layer.parameters():
            param.requires_grad = False
            
        # LoRA matrices
        self.lora_A = nn.Linear(original_layer.in_features, r, bias=False)
        self.lora_B = nn.Linear(r, original_layer.out_features, bias=False)
        self.dropout = nn.Dropout(dropout)
        
        # Initialize LoRA weights
        nn.init.kaiming_uniform_(self.lora_A.weight, a=math.sqrt(5))
        nn.init.zeros_(self.lora_B.weight)
        
    def forward(self, x):
        original_out = self.original_layer(x)
        lora_out = self.lora_A(x)
        lora_out = self.dropout(lora_out)
        lora_out = self.lora_B(lora_out)
        return original_out + (lora_out * self.scaling)
    
    def merge_weights(self):
        """Merge LoRA weights into original layer for inference"""
        if self.r > 0:
            lora_weight = (self.lora_B.weight @ self.lora_A.weight) * self.scaling
            self.original_layer.weight.data += lora_weight
            self.lora_A.weight.data.zero_()
            self.lora_B.weight.data.zero_()

def apply_lora_to_dinov2(model, r=16, alpha=32, target_modules=None):
    """Apply LoRA to DINOv2 attention layers"""
    if target_modules is None:
        target_modules = ['qkv', 'proj']
    
    lora_modules = {}
    
    def apply_lora_recursive(module, name=""):
        for child_name, child_module in module.named_children():
            full_name = f"{name}.{child_name}" if name else child_name
            
            if isinstance(child_module, nn.Linear) and any(target in full_name for target in target_modules):
                lora_layer = LoRALinear(child_module, r=r, alpha=alpha)
                setattr(module, child_name, lora_layer)
                lora_modules[full_name] = lora_layer
                print(f"Applied LoRA to: {full_name}")
            else:
                apply_lora_recursive(child_module, full_name)
    
    apply_lora_recursive(model)
    return lora_modules

class DINOv2MultiLabelClassifier(nn.Module):
    def __init__(self, num_classes, r=16, alpha=32):
        super().__init__()
        # Load DINOv2 backbone
        self.backbone = torch.hub.load('facebookresearch/dinov2', 'dinov2_vits14')
        
        # Apply LoRA
        self.lora_modules = apply_lora_to_dinov2(self.backbone, r=r, alpha=alpha)
        
        # Multi-label classification head
        self.classifier = nn.Linear(384, num_classes)  # 384 for ViT-S
        
        # For attention visualization
        self.attention_weights = None
        self.cls_features = None
        self._register_hooks()
        
        # Track LoRA parameters for optimizer
        self.lora_parameters = []
        for module in self.lora_modules.values():
            self.lora_parameters.extend([module.lora_A.weight, module.lora_B.weight])
    
    def _register_hooks(self):
        """Register hooks to capture attention weights and CLS features"""
        def attention_hook(module, input, output):
            # Capture attention weights from the last layer
            if hasattr(module, 'num_heads'):
                # This is an attention module
                self.attention_weights = output[1] if isinstance(output, tuple) else None
        
        def cls_hook(module, input, output):
            # Capture CLS token features
            self.cls_features = output.clone()
        
        # Register hook on the last attention layer for attention weights
        for name, module in self.backbone.named_modules():
            if 'blocks.11.attn' in name:  # Last attention layer
                module.register_forward_hook(attention_hook)
                break
        
        # Register hook on backbone output for CLS features
        self.backbone.register_forward_hook(cls_hook)
    
    def forward(self, x, return_attention=False):
        # Reset attention weights
        self.attention_weights = None
        
        features = self.backbone(x)  # [batch, 384]
        logits = self.classifier(features)  # [batch, num_classes]
        
        if return_attention:
            return logits, self.attention_weights, self.cls_features
        return logits
    
    def get_lora_parameters(self):
        """Get only LoRA parameters for optimizer"""
        return self.lora_parameters + list(self.classifier.parameters())
    
    def merge_and_save(self, path):
        """Merge LoRA weights and save for production inference"""
        for module in self.lora_modules.values():
            module.merge_weights()
        
        torch.save({
            'backbone_state_dict': self.backbone.state_dict(),
            'classifier_state_dict': self.classifier.state_dict(),
            'num_classes': self.classifier.out_features
        }, path)
        print(f"Merged model saved to {path}")

class ProductionDINOv2MultiLabelClassifier(nn.Module):
    """Production model with merged weights - no LoRA overhead"""
    def __init__(self, num_classes):
        super().__init__()
        self.backbone = torch.hub.load('facebookresearch/dinov2', 'dinov2_vits14')
        self.classifier = nn.Linear(384, num_classes)
        
        # For attention visualization
        self.attention_weights = None
        self.patch_embeddings = None
        self._register_attention_hooks()
    
    def _register_attention_hooks(self):
        """Register hooks to capture attention for visualization"""
        def attention_hook(module, input, output):
            # Capture attention weights from last layer
            # DINOv2 attention output format: [batch, num_heads, seq_len, seq_len]
            if len(output) > 1 and output[1] is not None:
                self.attention_weights = output[1].detach()
        
        def patch_hook(module, input, output):
            # Capture patch embeddings before attention
            self.patch_embeddings = output.detach()
        
        # Hook into the last attention layer
        last_block = None
        for name, module in self.backbone.named_modules():
            if name.startswith('blocks.11'):  # Last transformer block
                last_block = module
                break
        
        if last_block is not None:
            # Try to hook attention module
            if hasattr(last_block, 'attn'):
                last_block.attn.register_forward_hook(attention_hook)
    
    def forward(self, x, return_attention=False):
        self.attention_weights = None
        
        with torch.no_grad():
            features = self.backbone(x)
        logits = self.classifier(features)
        
        if return_attention:
            return logits, self.attention_weights
        return logits
    
    @classmethod
    def from_lora_checkpoint(cls, checkpoint_path):
        """Load from merged LoRA checkpoint"""
        checkpoint = torch.load(checkpoint_path, map_location='cpu')
        
        model = cls(checkpoint['num_classes'])
        model.backbone.load_state_dict(checkpoint['backbone_state_dict'])
        model.classifier.load_state_dict(checkpoint['classifier_state_dict'])
        
        return model

class AttentionVisualizer:
    def __init__(self, patch_size=14):
        self.patch_size = patch_size
    
    def visualize_attention(self, image, attention_weights, predictions, class_names, 
                          threshold=0.5, save_path=None):
        """
        Visualize attention maps for multi-label predictions
        
        Args:
            image: Original input image tensor [C, H, W]
            attention_weights: Attention weights [num_heads, seq_len, seq_len]
            predictions: Sigmoid predictions [num_classes]
            class_names: List of class names
            threshold: Threshold for positive predictions
        """
        if attention_weights is None:
            print("No attention weights captured")
            return
        
        # Convert image to numpy
        if torch.is_tensor(image):
            # Denormalize
            mean = torch.tensor([0.485, 0.456, 0.406]).view(3, 1, 1)
            std = torch.tensor([0.229, 0.224, 0.225]).view(3, 1, 1)
            image = image * std + mean
            image = torch.clamp(image, 0, 1)
            image_np = image.permute(1, 2, 0).cpu().numpy()
        else:
            image_np = image
        
        # Get positive predictions
        positive_preds = torch.where(predictions > threshold)[0]
        
        if len(positive_preds) == 0:
            print("No positive predictions above threshold")
            return
        
        # Average attention across heads and get CLS attention to patches
        if len(attention_weights.shape) == 4:
            attention_weights = attention_weights[0]  # Remove batch dimension
        
        # attention_weights: [num_heads, seq_len, seq_len]
        # We want CLS token (index 0) attention to patches (index 1:)
        cls_attention = attention_weights[:, 0, 1:].mean(dim=0)  # [num_patches]
        
        # Reshape to spatial dimensions
        num_patches_side = int(cls_attention.shape[0] ** 0.5)
        attention_map = cls_attention.reshape(num_patches_side, num_patches_side).cpu().numpy()
        
        # Resize attention map to image size
        h, w = image_np.shape[:2]
        attention_resized = cv2.resize(attention_map, (w, h))
        attention_resized = (attention_resized - attention_resized.min()) / (attention_resized.max() - attention_resized.min())
        
        # Create visualization
        num_pos_preds = len(positive_preds)
        fig, axes = plt.subplots(2, max(3, num_pos_preds), figsize=(4*max(3, num_pos_preds), 8))
        
        if num_pos_preds == 1:
            axes = axes.reshape(2, -1)
        
        # Original image
        axes[0, 0].imshow(image_np)
        axes[0, 0].set_title('Original Image')
        axes[0, 0].axis('off')
        
        # Attention map
        axes[0, 1].imshow(attention_resized, cmap='hot')
        axes[0, 1].set_title('Attention Map')
        axes[0, 1].axis('off')
        
        # Overlay
        axes[0, 2].imshow(image_np)
        axes[0, 2].imshow(attention_resized, alpha=0.6, cmap='hot')
        axes[0, 2].set_title('Attention Overlay')
        axes[0, 2].axis('off')
        
        # Individual class attention (if we have class-specific attention)
        for i, pred_idx in enumerate(positive_preds[:axes.shape[1]]):
            if i < axes.shape[1]:
                axes[1, i].imshow(image_np)
                axes[1, i].imshow(attention_resized, alpha=0.6, cmap='hot')
                class_name = class_names[pred_idx]
                confidence = predictions[pred_idx].item()
                axes[1, i].set_title(f'{class_name}\nConf: {confidence:.3f}')
                axes[1, i].axis('off')
        
        # Hide unused subplots
        for i in range(len(positive_preds), axes.shape[1]):
            if i < axes.shape[1]:
                axes[1, i].axis('off')
        
        plt.tight_layout()
        
        if save_path:
            plt.savefig(save_path, dpi=150, bbox_inches='tight')
        
        plt.show()
        
        return attention_resized
    
    def create_attention_heatmap(self, attention_weights, image_size=(224, 224)):
        """Create attention heatmap from weights"""
        if attention_weights is None:
            return None
        
        # Process attention weights
        if len(attention_weights.shape) == 4:
            attention_weights = attention_weights[0]  # Remove batch dimension
        
        # Average across heads and get CLS attention
        cls_attention = attention_weights[:, 0, 1:].mean(dim=0)
        
        # Reshape and resize
        num_patches_side = int(cls_attention.shape[0] ** 0.5)
        attention_map = cls_attention.reshape(num_patches_side, num_patches_side).cpu().numpy()
        
        # Resize to image size
        attention_resized = cv2.resize(attention_map, image_size)
        
        # Normalize
        attention_resized = (attention_resized - attention_resized.min()) / (attention_resized.max() - attention_resized.min())
        
        return attention_resized








