def analyze_bbox_sizes(annotation_file, image_dir):
    """Analyze bbox size distribution in your dataset"""
    with open(annotation_file, 'r') as f:
        coco_data = json.load(f)
    
    bbox_areas = []
    bbox_aspect_ratios = []
    
    for ann in coco_data['annotations']:
        bbox = ann['bbox']  # [x, y, width, height]
        w, h = bbox[2], bbox[3]
        area = w * h
        aspect_ratio = w / h if h > 0 else 0
        
        bbox_areas.append(area)
        bbox_aspect_ratios.append(aspect_ratio)
    
    fig, axes = plt.subplots(1, 2, figsize=(15, 5))
    
    # Area distribution
    axes[0].hist(bbox_areas, bins=50, alpha=0.7)
    axes[0].set_xlabel('Bbox Area (pixels²)')
    axes[0].set_ylabel('Count')
    axes[0].set_title('Bbox Area Distribution')
    axes[0].set_yscale('log')
    axes[0].grid(True, alpha=0.3)
    
    # Aspect ratio distribution
    axes[1].hist(bbox_aspect_ratios, bins=50, alpha=0.7)
    axes[1].set_xlabel('Aspect Ratio (W/H)')
    axes[1].set_ylabel('Count')
    axes[1].set_title('Bbox Aspect Ratio Distribution')
    axes[1].grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.show()
    
    print(f"Area statistics:")
    print(f"  Mean: {np.mean(bbox_areas):.1f}")
    print(f"  Median: {np.median(bbox_areas):.1f}")
    print(f"  Min: {np.min(bbox_areas):.1f}")
    print(f"  Max: {np.max(bbox_areas):.1f}")
    
