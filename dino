# Error analysis functions
def analyze_classification_errors(model, test_loader, class_names, num_errors=50):
    """Analyze classification errors in detail"""
    model.eval()
    errors = []
    
    with torch.no_grad():
        for data, labels, category_ids, ann_ids in test_loader:
            data, labels = data.cuda(), labels.cuda()
            outputs, cls_features = model(data, return_cls=True)
            
            probs = torch.softmax(outputs, dim=1)
            predictions = torch.argmax(outputs, dim=1)
            confidences = torch.max(probs, dim=1)[0]
            
            # Find errors
            error_mask = predictions != labels
            if error_mask.sum() > 0:
                for i in range(len(data)):
                    if error_mask[i]:
                        errors.append({
                            'ann_id': ann_ids[i].item(),
                            'true_label': labels[i].item(),
                            'pred_label': predictions[i].item(),
                            'confidence': confidences[i].item(),
                            'cls_features': cls_features[i].cpu(),
                            'image': data[i].cpu()
                        })
            
            if len(errors) >= num_errors:
                break
    
    # Sort by confidence (most confident errors first)
    errors.sort(key=lambda x: x['confidence'], reverse=True)
    
    # Visualize top errors
    fig, axes = plt.subplots(5, 10, figsize=(20, 10))
    axes = axes.flatten()
    
    for i in range(min(50, len(errors))):
        error = errors[i]
        
        # Denormalize image for visualization
        img = error['image'].permute(1, 2, 0)
        img = img * torch.tensor([0.229, 0.224, 0.225]) + torch.tensor([0.485, 0.456, 0.406])
        img = torch.clamp(img, 0, 1)
        
        axes[i].imshow(img)
        axes[i].set_title(f'True: {class_names[error["true_label"]]}\n'
                         f'Pred: {class_names[error["pred_label"]]}\n'
                         f'Conf: {error["confidence"]:.3f}', fontsize=8)
        axes[i].axis('off')
    
    plt.tight_layout()
    plt.suptitle('Most Confident Classification Errors', y=1.02, fontsize=16)
    plt.show()
    
    return errors

def compute_per_class_metrics_detailed(labels, predictions, class_names):
    """Compute detailed per-class metrics"""
    from sklearn.metrics import precision_recall_fscore_support, confusion_matrix
    
    # Per-class metrics
    precision, recall, f1, support = precision_recall_fscore_support(
        labels, predictions, average=None, zero_division=0
    )
    
    # Confusion matrix for detailed analysis
    cm = confusion_matrix(labels, predictions)
    
    print("\nDetailed Per-Class Metrics:")
    print("-" * 80)
    print(f"{'Class':<20} {'Precision':<10} {'Recall':<10} {'F1-Score':<10} {'Support':<10}")
    print("-" * 80)
    
    for i, class_name in enumerate(class_names):
