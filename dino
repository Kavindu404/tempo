class CLSVisualizer:
    def __init__(self, class_names=None, save_dir='./visualizations'):
        self.class_names = class_names
        self.save_dir = save_dir
        os.makedirs(save_dir, exist_ok=True)
        
        # Color palette for classes
        self.colors = plt.cm.tab10(np.linspace(0, 1, 10))
        
    def visualize_cls_tokens(self, cls_features, labels, predictions=None, 
                           epoch=None, batch_idx=None, method='tsne'):
        """
        Visualize CLS token embeddings
        
        Args:
            cls_features: [batch_size, 384] CLS token features
            labels: [batch_size] ground truth labels
            predictions: [batch_size] predicted labels (optional)
            method: 'tsne' or 'pca' for dimensionality reduction
        """
        # Convert to numpy
        if torch.is_tensor(cls_features):
            cls_features = cls_features.cpu().numpy()
        if torch.is_tensor(labels):
            labels = labels.cpu().numpy()
        if predictions is not None and torch.is_tensor(predictions):
            predictions = predictions.cpu().numpy()
        
        # Dimensionality reduction
        if method == 'tsne':
            reducer = TSNE(n_components=2, random_state=42, perplexity=min(30, len(cls_features)-1))
        else:
            reducer = PCA(n_components=2, random_state=42)
        
        embedded = reducer.fit_transform(cls_features)
        
        # Create visualization
        fig, axes = plt.subplots(1, 2 if predictions is not None else 1, 
                                figsize=(15 if predictions is not None else 8, 6))
        
        if predictions is None:
            axes = [axes]
        
        # Plot ground truth
        self._plot_embeddings(axes[0], embedded, labels, 
                             title=f'CLS Tokens - Ground Truth ({method.upper()})')
        
        # Plot predictions if available
        if predictions is not None:
            self._plot_embeddings(axes[1], embedded, predictions,
                                 title=f'CLS Tokens - Predictions ({method.upper()})')
            
            # Add accuracy to title
            accuracy = (labels == predictions).mean()
            axes[1].set_title(axes[1].get_title() + f'\nAccuracy: {accuracy:.3f}')
        
        plt.tight_layout()
        
        # Save if epoch/batch info provided
        if epoch is not None:
            filename = f'cls_visualization_epoch_{epoch}'
            if batch_idx is not None:
                filename += f'_batch_{batch_idx}'
            filename += f'_{method}.png'
            
            plt.savefig(os.path.join(self.save_dir, filename), dpi=150, bbox_inches='tight')
            print(f"Saved visualization: {filename}")
        
        plt.show()
        
    def _plot_embeddings(self, ax, embedded, labels, title):
        """Helper function to plot embeddings"""
        unique_labels = np.unique(labels)
        
        for i, label in enumerate(unique_labels):
            mask = labels == label
            label_name = self.class_names[label] if self.class_names else f'Class {label}'
            
            ax.scatter(embedded[mask, 0], embedded[mask, 1], 
                      c=[self.colors[label % len(self.colors)]], 
                      label=label_name, alpha=0.7, s=50)
        
        ax.set_title(title)
        ax.legend(bbox_to_anchor=(1.05, 1), loc='upper left')
        ax.grid(True, alpha=0.3)
    
    def plot_cls_evolution(self, cls_history, labels_history, epochs):
        """Plot how CLS tokens evolve during training"""
        fig, axes = plt.subplots(2, 3, figsize=(18, 12))
        axes = axes.flatten()
        
        # Select epochs to visualize
        epoch_indices = np.linspace(0, len(cls_history)-1, 6, dtype=int)
        
        for i, epoch_idx in enumerate(epoch_indices):
            cls_features = cls_history[epoch_idx]
            labels = labels_history[epoch_idx]
            
            # Use PCA for consistency across epochs
            pca = PCA(n_components=2, random_state=42)
            embedded = pca.fit_transform(cls_features)
            
            self._plot_embeddings(axes[i], embedded, labels, 
                                f'Epoch {epochs[epoch_idx]}')
        
        plt.tight_layout()
        plt.savefig(os.path.join(self.save_dir, 'cls_evolution.png'), 
                    dpi=150, bbox_inches='tight')
        plt.show()



