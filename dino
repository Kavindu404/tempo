                val_cls_features[:200],  # Subset for clarity
                val_labels[:200],
                val_preds[:200],
                epoch=epoch,
                method='tsne'
            )
        
        # Plot training curves every 10 epochs
        if (epoch + 1) % 10 == 0:
            tracker.plot_training_curves()
    
    # Final plots and save
    tracker.plot_training_curves()
    tracker.save_metrics()
    
    # Load best model
    if best_model_state:
        model.load_state_dict(best_model_state)
        print(f'Loaded best model with validation accuracy: {best_val_acc:.4f}')
    
    return model, tracker

def validate_coco_classifier(model, val_loader, criterion):
    """Validation with detailed metrics"""
    model.eval()
    val_loss = 0
    correct = 0
    total = 0
    
    all_cls_features = []
    all_labels = []
    all_predictions = []
    
    with torch.no_grad():
        for data, labels, category_ids, ann_ids in val_loader:
            data, labels = data.cuda(), labels.cuda()
            
            outputs, cls_features = model(data, return_cls=True)
            loss = criterion(outputs, labels)
            
            val_loss += loss.item() * data.size(0)
            
            _, predicted = torch.max(outputs.data, 1)
            total += labels.size(0)
            correct += (predicted == labels).sum().item()
            
            # Collect for analysis
            all_cls_features.append(cls_features.cpu())
            all_labels.append(labels.cpu())
            all_predictions.append(predicted.cpu())
    
    model.train()
    
    # Concatenate results
    all_cls_features = torch.cat(all_cls_features)
    all_labels = torch.cat(all_labels)
    all_predictions = torch.cat(all_predictions)
    
    avg_val_loss = val_loss / total
    accuracy = correct / total
    
    return avg_val_loss, accuracy, all_cls_features, all_labels, all_predictions



