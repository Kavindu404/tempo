def create_data_splits(annotation_file, train_ratio=0.7, val_ratio=0.15, test_ratio=0.15):
    """Split COCO annotations into train/val/test"""
    with open(annotation_file, 'r') as f:
        coco_data = json.load(f)
    
    # Group annotations by image_id
    image_annotations = defaultdict(list)
    for ann in coco_data['annotations']:
        image_annotations[ann['image_id']].append(ann)
    
    # Split images
    image_ids = list(image_annotations.keys())
    np.random.shuffle(image_ids)
    
    n_train = int(len(image_ids) * train_ratio)
    n_val = int(len(image_ids) * val_ratio)
    
    train_image_ids = set(image_ids[:n_train])
    val_image_ids = set(image_ids[n_train:n_train + n_val])
    test_image_ids = set(image_ids[n_train + n_val:])
    
    # Create splits
    splits = {
        'train': {'images': [], 'annotations': []},
        'val': {'images': [], 'annotations': []},
        'test': {'images': [], 'annotations': []}
    }
    
    # Add images and annotations to splits
    for img in coco_data['images']:
        img_id = img['id']
        if img_id in train_image_ids:
            splits['train']['images'].append(img)
            splits['train']['annotations'].extend(image_annotations[img_id])
        elif img_id in val_image_ids:
            splits['val']['images'].append(img)
            splits['val']['annotations'].extend(image_annotations[img_id])
        elif img_id in test_image_ids:
            splits['test']['images'].append(img)
            splits['test']['annotations'].extend(image_annotations[img_id])
    
    # Save splits
    for split_name, split_data in splits.items():
        output_data = {
            'images': split_data['images'],
            'annotations': split_data['annotations'],
            'categories': coco_data['categories']
        }
        
        with open(f'{split_name}_annotations.json', 'w') as f:
            json.dump(output_data, f)
        
        print(f"{split_name}: {len(split_data['images'])} images, {len(split_data['annotations'])} annotations")

