class ProductionDINOv2Classifier(nn.Module):
    def __init__(self, num_classes):
        super().__init__()
        self.backbone = torch.hub.load('facebookresearch/dinov2', 'dinov2_vits14')
        self.classifier = nn.Linear(384, num_classes)
        
        # Hook for CLS extraction
        self.cls_features = None
        self._register_cls_hook()
    
    def _register_cls_hook(self):
        def hook_fn(module, input, output):
            self.cls_features = output.clone()
        self.backbone.register_forward_hook(hook_fn)
    
    def forward(self, x, return_cls=False):
        features = self.backbone(x)
        logits = self.classifier(features)
        
        if return_cls:
            return logits, self.cls_features
        return logits
    
    def analyze_predictions(self, dataloader, class_names=None, visualize=True):
        """Analyze predictions with CLS visualization"""
        self.eval()
        
        all_cls_features = []
        all_labels = []
        all_predictions = []
        all_confidences = []
        
        with torch.no_grad():
            for data, target in dataloader:
                data, target = data.cuda(), target.cuda()
                
                logits, cls_features = self(data, return_cls=True)
                probs = torch.softmax(logits, dim=1)
                predictions = torch.argmax(probs, dim=1)
                confidences = torch.max(probs, dim=1)[0]
                
                all_cls_features.append(cls_features.cpu())
                all_labels.append(target.cpu())
                all_predictions.append(predictions.cpu())
                all_confidences.append(confidences.cpu())
        
        # Concatenate results
        cls_features = torch.cat(all_cls_features)
        labels = torch.cat(all_labels)
        predictions = torch.cat(all_predictions)
        confidences = torch.cat(all_confidences)
        
        if visualize:
            visualizer = CLSVisualizer(class_names=class_names)
            
            # Overall visualization
            visualizer.visualize_cls_tokens(cls_features, labels, predictions)
            
            # Visualize by confidence
            self._visualize_by_confidence(visualizer, cls_features, labels, 
                                        predictions, confidences)
        
        return {
            'cls_features': cls_features,
            'labels': labels,
            'predictions': predictions,
            'confidences': confidences,
            'accuracy': (labels == predictions).float().mean().item()
        }
    
    def _visualize_by_confidence(self, visualizer, cls_features, labels, 
                               predictions, confidences):
        """Visualize CLS tokens colored by confidence"""
        # Split by confidence levels
        high_conf_mask = confidences > 0.9
        medium_conf_mask = (confidences > 0.7) & (confidences <= 0.9)
        low_conf_mask = confidences <= 0.7
        
        fig, axes = plt.subplots(1, 3, figsize=(20, 6))
        
        for i, (mask, title) in enumerate([
            (high_conf_mask, 'High Confidence (>0.9)'),
            (medium_conf_mask, 'Medium Confidence (0.7-0.9)'),
            (low_conf_mask, 'Low Confidence (≤0.7)')
        ]):
            if mask.sum() > 1:  # Need at least 2 points for visualization
                # Use PCA for consistency
                pca = PCA(n_components=2, random_state=42)
                embedded = pca.fit_transform(cls_features[mask])
                
                visualizer._plot_embeddings(axes[i], embedded, labels[mask], title)
                
                # Add accuracy info
                acc = (labels[mask] == predictions[mask]).float().mean()
                axes[i].set_title(f'{title}\nAccuracy: {acc:.3f} (n={mask.sum()})')
            else:
                axes[i].text(0.5, 0.5, 'Insufficient data', 
                           ha='center', va='center', transform=axes[i].transAxes)
                axes[i].set_title(title)
        
        plt.tight_layout()
        plt.savefig(os.path.join(visualizer.save_dir, 'confidence_analysis.png'), 
                    dpi=150, bbox_inches='tight')
        plt.show()


