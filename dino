              f"{f1[i]:<10.4f} {support[i]:<10}")
    
    # Find most confused pairs
    print("\nMost Confused Class Pairs:")
    print("-" * 50)
    
    conf_pairs = []
    for i in range(len(class_names)):
        for j in range(len(class_names)):
            if i != j and cm[i, j] > 0:
                conf_pairs.append((cm[i, j], class_names[i], class_names[j]))
    
    conf_pairs.sort(reverse=True)
    for count, true_class, pred_class in conf_pairs[:10]:
        print(f"{true_class} -> {pred_class}: {count} errors")
        
        
