import torch
import torch.nn as nn
import matplotlib.pyplot as plt
import numpy as np
from sklearn.manifold import TSNE
from sklearn.decomposition import PCA
import seaborn as sns

class DINOv2LoRAClassifier(nn.Module):
    def __init__(self, num_classes, r=16, alpha=32, return_features=False):
        super().__init__()
        self.backbone = torch.hub.load('facebookresearch/dinov2', 'dinov2_vits14')
        self.lora_modules = apply_lora_to_dinov2(self.backbone, r=r, alpha=alpha)
        self.classifier = nn.Linear(384, num_classes)
        self.return_features = return_features
        
        # Hook to capture CLS token
        self.cls_features = None
        self._register_cls_hook()
        
        self.lora_parameters = []
        for module in self.lora_modules.values():
            self.lora_parameters.extend([module.lora_A.weight, module.lora_B.weight])
    
    def _register_cls_hook(self):
        """Register hook to capture CLS token from backbone"""
        def hook_fn(module, input, output):
            # DINOv2 returns the CLS token directly
            self.cls_features = output.clone()
        
        # Register hook on the backbone's forward
        self.backbone.register_forward_hook(hook_fn)
    
    def forward(self, x, return_cls=False):
        features = self.backbone(x)  # This triggers the hook
        logits = self.classifier(features)
        
        if return_cls or self.return_features:
            return logits, self.cls_features
        return logits
    
    def get_cls_features(self, x):
        """Extract CLS features without computing logits"""
        with torch.no_grad():
            _ = self.backbone(x)
            return self.cls_features.clone()
